# ==============================================================
# 3D Print Shop — Environment Variables (EXAMPLE — no real keys!)
# Copy to .env and fill in real values. Never commit .env files.
# ==============================================================

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://printshop:printshop@localhost:5432/printshop?schema=public"

# --- API ---
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
# Secret for signing session JWTs (generate with: openssl rand -hex 32)
JWT_SECRET="change-me-in-production"
COOKIE_SECURE=false

# --- Uploads ---
UPLOAD_DIR="./uploads"
UPLOAD_MAX_BYTES=52428800

# --- Resend (emails) — leave empty for dev-mode logging ---
RESEND_API_KEY=""
EMAIL_FROM="Print Shop <noreply@example.com>"
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# --- Stripe — leave empty for dev-mock mode ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# --- Bitcoin payment provider ---
# "mock" (default, no blockchain access) or "blockchain-api" (real provider, see docs/payments.md)
BITCOIN_PROVIDER="mock"
# xpub for deriving receive addresses — NEVER put a private key here
BITCOIN_XPUB=""
BITCOIN_REQUIRED_CONFIRMATIONS=2

# --- Bank transfer details shown to customers ---
BANK_ACCOUNT_HOLDER="Print Shop GmbH"
BANK_IBAN="DE00 0000 0000 0000 0000 00"
BANK_BIC="XXXXDEXXXXX"

# --- Tracking placeholders (loaded only after consent opt-in) ---
NUXT_PUBLIC_GA4_MEASUREMENT_ID=""
NUXT_PUBLIC_META_PIXEL_ID=""

# --- Invoices ---
INVOICE_DIR="./invoices"
INVOICE_PREFIX="RE"
