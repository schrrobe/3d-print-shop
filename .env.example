# ==============================================================
# 3D Print Shop — Environment Variables (EXAMPLE — no real keys!)
# Copy to .env and fill in real values. Never commit .env files.
# ==============================================================

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://printshop:printshop@localhost:15433/printshop?schema=public"

# --- API ---
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
# Secret for signing session JWTs (generate with: openssl rand -hex 32)
JWT_SECRET="change-me-in-production"
COOKIE_SECURE=false

# --- Uploads ---
# Model uploads plus private subdirs complaints/, qc/, reviews/ (created on demand).
# Those subdirs are NEVER served statically — only via token-/permission-gated endpoints.
UPLOAD_DIR="./uploads"
UPLOAD_MAX_BYTES=52428800

# --- Resend (emails) — leave empty for dev-mode logging ---
RESEND_API_KEY=""
EMAIL_FROM="Print Shop <noreply@example.com>"
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# --- Inbound ticket replies (optional; both empty = feature off) ---
# Subdomain whose MX record points to Resend receiving, e.g. reply.example.com
TICKET_REPLY_DOMAIN=""
# Signing secret of the Resend "email.received" webhook (whsec_...)
RESEND_WEBHOOK_SECRET=""

# --- Stripe — leave empty for dev-mock mode ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# --- Bitcoin payment provider ---
# "mock" (default, no blockchain access) or "blockchain-api" (real provider, see docs/payments.md)
BITCOIN_PROVIDER="mock"
# xpub for deriving receive addresses — NEVER put a private key here
BITCOIN_XPUB=""
BITCOIN_REQUIRED_CONFIRMATIONS=2

# --- Bank transfer details shown to customers ---
BANK_ACCOUNT_HOLDER="Print Shop GmbH"
BANK_IBAN="DE00 0000 0000 0000 0000 00"
BANK_BIC="XXXXDEXXXXX"

# --- Tracking placeholders (loaded only after consent opt-in) ---
NUXT_PUBLIC_GA4_MEASUREMENT_ID=""
NUXT_PUBLIC_META_PIXEL_ID=""

# --- SEO: public base URL for canonical/hreflang/og:url/sitemap (production domain) ---
NUXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Invoices ---
INVOICE_DIR="./invoices"
INVOICE_PREFIX="RE"
# Company identity printed on the invoice PDF (placeholders — set real values before go-live)
COMPANY_NAME="Print Shop GmbH"
COMPANY_STREET="Musterstraße 1"
COMPANY_ZIP="12345"
COMPANY_CITY="Berlin"
COMPANY_EMAIL="info@example.com"
COMPANY_PHONE="+49 30 0000000"
COMPANY_WEBSITE="www.example.com"
# Steuernummer (invoice footer; the §19 UStG small-business note is printed automatically)
COMPANY_TAX_NUMBER="12/345/67890"
COMPANY_OWNER="Max Mustermann"
# Optional PNG/JPEG letterhead logo (absolute path or relative to apps/api); empty = text letterhead
INVOICE_LOGO_PATH=""
# Payment target in days, printed on unpaid bank-transfer invoices
PAYMENT_TERMS_DAYS=14
# Print the §19 UStG small-business "no VAT charged" note on invoices. Set false once VAT-liable.
COMPANY_VAT_EXEMPT=true

# --- Social media publishing (Meta Graph API) ---
# "mock" (default, no external calls) or "meta" (official Graph API — needs META_* vars)
SOCIAL_PUBLISHING_PROVIDER="mock"
# Background worker that publishes due posts (true in production, see docs/social-media-planner.md)
SOCIAL_PUBLISHING_CRON_ENABLED=false
SOCIAL_PUBLISHING_CRON_INTERVAL_SECONDS=60
# Meta app credentials — server-side only, NEVER expose tokens to the frontend
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_API_VERSION="v23.0"
# Facebook page feed posts
META_FACEBOOK_PAGE_ID=""
META_FACEBOOK_PAGE_ACCESS_TOKEN=""
# Instagram feed posts (Business/Creator account linked to the Facebook page)
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=""
META_INSTAGRAM_ACCESS_TOKEN=""
