// 3D Print Shop — data model
// Enum values mirror @print-shop/types (English snake_case keys, i18n labels in the frontend).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum RoleName {
  admin
  product_manager
  production
  shipping
  support
}

enum Locale {
  de
  en
  pl
  fr
  nl
  cs
}

enum OrderStatus {
  pending
  awaiting_payment
  awaiting_bank_transfer
  paid
  in_production
  quality_check
  ready_to_ship
  shipped
  completed
  cancelled
  refunded
}

enum PaymentMethod {
  stripe
  stripe_payment_link
  bank_transfer
  bitcoin
}

enum PaymentStatus {
  pending
  processing
  paid
  failed
  refunded
  expired
}

enum BitcoinPaymentStatus {
  awaiting_payment
  unconfirmed
  confirming
  paid
  underpaid
  expired
}

enum QuoteRequestStatus {
  new
  in_review
  quoted
  accepted
  rejected
  cancelled
}

enum QuoteStatus {
  draft
  sent
  accepted
  declined
  expired
}

/// frei, vorbereitet, druckt, pausiert, fehler, wartung
enum PrinterStatus {
  idle
  prepared
  printing
  paused
  error
  maintenance
}

/// wartet, zugewiesen, druckt, fertig, qualitätsprüfung, versandbereit, versendet, fehlgeschlagen, reprint_nötig
enum ProductionStatus {
  waiting
  assigned
  printing
  printed
  quality_check
  ready_to_ship
  shipped
  failed
  reprint_needed
}

enum AssetType {
  image
  glb_preview
  production_file
}

enum Carrier {
  dhl
  hermes
}

enum ColorZoneSlot {
  zone_1_main
  zone_2_accent
  zone_3_detail
  zone_4_text
}

enum EmailStatus {
  sent
  dev_logged
  failed
}

enum TicketStatus {
  open
  in_progress
  waiting_customer
  resolved
  closed
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

enum TicketCategory {
  order
  payment
  shipping
  product
  other
}

enum TicketAuthorType {
  customer
  staff
}

enum SocialPlatform {
  instagram
  facebook
}

/// entwurf, geplant, wird veröffentlicht (Worker-Lock), veröffentlicht, fehlgeschlagen, abgebrochen
enum SocialPostStatus {
  draft
  scheduled
  publishing
  published
  failed
  cancelled
}

/// eingereicht, in Prüfung, weitere Infos benötigt, genehmigt, abgelehnt, Ersatzdruck geplant, Erstattung geplant, abgeschlossen
enum ComplaintStatus {
  submitted
  in_review
  info_needed
  approved
  rejected
  replacement_planned
  refund_planned
  closed
}

enum ComplaintReason {
  damaged
  wrong_item
  quality_issue
  missing_parts
  color_mismatch
  other
}

/// Ersatzdruck, Erstattung, Gutschein, Ablehnung, weitere Prüfung
enum ComplaintResolution {
  replacement_print
  refund
  voucher
  rejection
  further_review
}

enum AttachmentAuthor {
  customer
  staff
}

/// offen, bestanden, fehlgeschlagen, Reprint erforderlich, überschrieben
enum QcStatus {
  open
  passed
  failed
  reprint_required
  overridden
}

enum AmsSlotStatus {
  empty
  loaded
  low
  error
  disabled
}

/// wartet auf QC, bereit für Versand, verpackt, versendet, zugestellt, Problem
enum ShipmentStatus {
  waiting_for_qc
  ready_for_shipping
  packed
  shipped
  delivered
  problem
}

/// ausstehend, freigegeben, abgelehnt, ausgeblendet
enum ReviewStatus {
  pending
  approved
  rejected
  hidden
}

// ---------- Auth / RBAC ----------

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  /// Incremented on password changes to invalidate all previously issued JWTs.
  sessionVersion Int      @default(0)
  /// Sessions issued before this moment are rejected (set on logout).
  sessionsInvalidatedAt DateTime?
  active         Boolean  @default(true)
  roleId         String
  role           Role     @relation(fields: [roleId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs       AdminAuditLog[]      @relation("AuditActor")
  passwordResets  PasswordResetToken[]
  assignedTickets Ticket[]             @relation("TicketAssignee")
  ticketMessages  TicketMessage[]      @relation("TicketMessageAuthor")
  socialPosts     SocialMediaPost[]    @relation("SocialPostAuthor")

  complaintDecisions ComplaintDecision[]   @relation("ComplaintDecider")
  qcApprovals        QcRecord[]            @relation("QcApprover")
  moderatedReviews   Review[]              @relation("ReviewModerator")
  maintenanceWindows MaintenanceWindow[]   @relation("MaintenanceAuthor")
  shipments          Shipment[]            @relation("ShipmentAuthor")
  shipmentEvents     ShipmentStatusEvent[] @relation("ShipmentEventActor")
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique
  permissions Permission[]
  users       User[]
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  roles Role[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ---------- Catalog ----------

model Product {
  id         String   @id @default(cuid())
  slug       String   @unique
  priceCents Int
  active     Boolean  @default(false)
  /// Sonderanfertigung (made-to-order / farblich personalisiert): kein Widerruf,
  /// nur Reklamation/Kulanz. Steuert den Hinweis im Reklamations-Formular.
  customMade Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  translations        ProductTranslation[]
  assets              ProductAsset[]
  colorSlots          ProductColorSlot[]
  orderItems          OrderItem[]
  cartItems           CartItem[]
  socialPosts         SocialMediaPost[]
  reviews             Review[]
  savedConfigurations SavedConfiguration[]
}

model ProductTranslation {
  id             String  @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale         Locale
  name           String
  description    String
  seoTitle       String?
  seoDescription String?

  @@unique([productId, locale])
}

model ProductAsset {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      AssetType
  url       String
  alt       String?
  sortOrder Int       @default(0)
}

model ProductColorSlot {
  id             String        @id @default(cuid())
  productId      String
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  slot           ColorZoneSlot
  label          String
  defaultColorId String?
  defaultColor   Color?        @relation(fields: [defaultColorId], references: [id])

  @@unique([productId, slot])
}

model Color {
  id            String  @id @default(cuid())
  name          String  @unique
  hex           String
  material      String
  manufacturer  String
  active        Boolean @default(true)
  stockGrams    Int?
  amsSlot       Int?
  /// Mindestbestand über alle Spulen dieser Farbe (Gramm); unterschritten → Warnung/Einkaufsliste
  minStockGrams Int?
  /// „Aktuell nicht verfügbar": bleibt im Shop sichtbar, aber nicht wählbar (active=false versteckt komplett)
  outOfStock    Boolean @default(false)

  defaultForSlots ProductColorSlot[]
  filamentSpools  FilamentSpool[]
}

// ---------- Cart ----------

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id             String  @id @default(cuid())
  cartId         String
  cart           Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  colorSelection Json
}

// ---------- Vouchers ----------

enum VoucherType {
  percent
  fixed
}

model Voucher {
  id              String      @id @default(cuid())
  /// Stored uppercase; lookups normalize input to uppercase
  code            String      @unique
  type            VoucherType
  /// percent: 1-100, fixed: cents
  value           Int
  active          Boolean     @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  maxRedemptions  Int?
  redemptionCount Int         @default(0)
  minOrderCents   Int         @default(0)
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orders Order[]
}

// ---------- Orders ----------

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  /// Token for guest access to confirmation / status page
  accessToken    String      @unique
  /// Client-generated retry key; prevents duplicate orders on checkout retries.
  checkoutKey    String?     @unique
  status         OrderStatus @default(pending)
  locale         Locale      @default(de)
  email          String
  firstName      String
  lastName       String
  company        String?
  street         String
  zip            String
  city           String
  country        String
  phone          String?
  note           String?
  subtotalCents  Int
  shippingCents  Int
  discountCents  Int         @default(0)
  totalCents     Int
  /// Snapshot of the redeemed voucher code (kept even if the voucher is deleted)
  voucherCode    String?
  voucherId      String?
  voucher        Voucher?    @relation(fields: [voucherId], references: [id])
  carrier        Carrier?
  trackingNumber String?
  shippedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items       OrderItem[]
  payments    Payment[]
  invoice     Invoice?
  printerJobs PrinterJob[]
  quotes      Quote[]
  tickets     Ticket[]
  complaints  Complaint[]
  shipments   Shipment[]
  reviews     Review[]

  @@index([voucherId])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id])
  /// Snapshot of the product/quote name at purchase time
  name           String
  quantity       Int
  unitPriceCents Int
  colorSelection Json?

  printerJobs    PrinterJob[]
  complaintItems ComplaintItem[]
  shipmentItems  ShipmentItem[]
  review         Review?
}

// ---------- Payments ----------

model Payment {
  id                   String        @id @default(cuid())
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method               PaymentMethod
  status               PaymentStatus @default(pending)
  amountCents          Int
  /// Stripe checkout session / payment link id
  stripeSessionId      String?       @unique
  stripePaymentLinkUrl String?
  /// Manual reference (e.g. bank transfer reference)
  reference            String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  bitcoinPayment BitcoinPayment?
}

model BitcoinPayment {
  id            String               @id @default(cuid())
  paymentId     String               @unique
  payment       Payment              @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  /// Receive address (derived from xpub) or payment reference
  address       String
  expectedSats  BigInt
  receivedSats  BigInt               @default(0)
  confirmations Int                  @default(0)
  status        BitcoinPaymentStatus @default(awaiting_payment)
  expiresAt     DateTime
  txId          String?
  updatedAt     DateTime             @updatedAt
  createdAt     DateTime             @default(now())
}

// ---------- Upload requests & quotes ----------

model QuoteRequest {
  id                  String             @id @default(cuid())
  status              QuoteRequestStatus @default(new)
  name                String
  email               String
  phone               String?
  description         String
  quantity            Int                @default(1)
  locale              Locale             @default(de)
  /// Placeholder: acceptance of future legal upload terms
  acceptedUploadTerms Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  files  UploadedFile[]
  quotes Quote[]
}

model UploadedFile {
  id             String       @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  originalName   String
  storedPath     String
  extension      String
  sizeBytes      Int
  createdAt      DateTime     @default(now())
}

model Quote {
  id             String       @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  status         QuoteStatus  @default(draft)
  priceCents     Int
  message        String?
  /// Public token for the customer-facing quote/acceptance page
  token          String       @unique
  validUntil     DateTime
  sentAt         DateTime?
  decidedAt      DateTime?
  /// Order created after acceptance
  orderId        String?
  order          Order?       @relation(fields: [orderId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ---------- Production ----------

model Printer {
  id        String        @id @default(cuid())
  name      String        @unique
  model     String
  status    PrinterStatus @default(idle)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  jobs               PrinterJob[]
  amsUnits           AmsUnit[]
  maintenanceWindows MaintenanceWindow[]
}

model PrinterJob {
  id                   String           @id @default(cuid())
  printerId            String?
  printer              Printer?         @relation(fields: [printerId], references: [id])
  orderId              String
  order                Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId          String?
  orderItem            OrderItem?       @relation(fields: [orderItemId], references: [id])
  status               ProductionStatus @default(waiting)
  printDurationMinutes Int?
  /// Produktionskalender: geplantes Zeitfenster (UTC; Anzeige in Admin-Zeitzone)
  plannedStartAt       DateTime?
  plannedEndAt         DateTime?
  startedAt            DateTime?
  finishedAt           DateTime?
  /// AMS slot / spool assignment documentation
  spoolNotes           String?
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  qcRecords         QcRecord[]
  complaintDecision ComplaintDecision?

  @@index([printerId, plannedStartAt])
}

model FilamentSpool {
  id                String   @id @default(cuid())
  colorId           String?
  color             Color?   @relation(fields: [colorId], references: [id])
  material          String
  manufacturer      String?
  /// Anzeigename / Charge, z. B. "PLA Matte Schwarz #2"
  label             String?
  totalGrams        Int?
  remainingGrams    Int?
  /// Mindestbestand dieser Spule (Gramm); unterschritten → Warnung
  minRemainingGrams Int?
  storageLocation   String?
  active            Boolean  @default(true)
  /// Nachbestellen-Flag → erscheint auf der Einkaufsliste
  reorder           Boolean  @default(false)
  notes             String?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  amsSlotAssignment AmsSlot?
}

/// AMS-Einheit eines Druckers (Bambu Lab AMS 2 Pro: bis 4 Units × 4 Slots)
model AmsUnit {
  id        String   @id @default(cuid())
  printerId String
  printer   Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slots AmsSlot[]

  @@unique([printerId, position])
}

model AmsSlot {
  id        String         @id @default(cuid())
  amsUnitId String
  amsUnit   AmsUnit        @relation(fields: [amsUnitId], references: [id], onDelete: Cascade)
  /// Slot-Nummer innerhalb der Unit (1–4)
  slotIndex Int
  status    AmsSlotStatus  @default(empty)
  /// Eine Spule kann nur in genau einem Slot stecken
  spoolId   String?        @unique
  spool     FilamentSpool? @relation(fields: [spoolId], references: [id])
  notes     String?
  updatedAt DateTime       @updatedAt

  @@unique([amsUnitId, slotIndex])
}

/// Wartungsfenster blockiert den Drucker im Produktionskalender (UTC)
model MaintenanceWindow {
  id          String   @id @default(cuid())
  printerId   String
  printer     Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
  title       String
  startsAt    DateTime
  endsAt      DateTime
  notes       String?
  createdById String?
  createdBy   User?    @relation("MaintenanceAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([printerId, startsAt])
}

// ---------- Qualitätskontrolle ----------

/// QC-Prüfung eines Druckauftrags vor Versand. Mehrere Records pro Job = Historie
/// (nach Reprint entsteht ein neuer Record). Aktueller Stand = neuester Record.
model QcRecord {
  id           String     @id @default(cuid())
  printerJobId String
  printerJob   PrinterJob @relation(fields: [printerJobId], references: [id])
  shipmentId   String?
  shipment     Shipment?  @relation(fields: [shipmentId], references: [id])
  status       QcStatus   @default(open)

  colorOk        Boolean @default(false)
  surfaceOk      Boolean @default(false)
  dimensionsOk   Boolean @default(false)
  stabilityOk    Boolean @default(false)
  completenessOk Boolean @default(false)
  packagingOk    Boolean @default(false)

  note           String?
  /// Pflicht bei Status "overridden" (bewusste Freigabe trotz nicht bestandener QC)
  overrideReason String?
  approvedById   String?
  approvedBy     User?     @relation("QcApprover", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  attachments QcAttachment[]

  @@index([printerJobId])
  @@index([status])
}

model QcAttachment {
  id           String   @id @default(cuid())
  qcRecordId   String
  qcRecord     QcRecord @relation(fields: [qcRecordId], references: [id], onDelete: Cascade)
  originalName String
  /// Absoluter Pfad im UPLOAD_DIR — niemals in Public-Responses
  storedPath   String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())
}

// ---------- Invoices ----------

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  year          Int
  sequence      Int
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  locale        Locale        @default(de)
  subtotalCents Int
  shippingCents Int
  discountCents Int           @default(0)
  totalCents    Int
  paymentMethod PaymentMethod
  pdfPath       String?
  issuedAt      DateTime      @default(now())

  @@unique([year, sequence])
}

/// Single-row-per-year counter for sequential invoice numbers (locked via transaction)
model InvoiceCounter {
  year         Int @id
  lastSequence Int @default(0)
}

// ---------- Support tickets ----------

model Ticket {
  id           String         @id @default(cuid())
  /// Human-readable sequential number, e.g. TIC-2026-00001
  ticketNumber String         @unique
  /// Public token for the customer-facing ticket thread page
  accessToken  String         @unique
  status       TicketStatus   @default(open)
  priority     TicketPriority @default(normal)
  category     TicketCategory @default(other)
  subject      String
  name         String
  email        String
  locale       Locale         @default(de)
  orderId      String?
  order        Order?         @relation(fields: [orderId], references: [id])
  assignedToId String?
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  messages  TicketMessage[]
  complaint Complaint?

  @@index([status, priority])
  @@index([assignedToId])
  @@index([orderId])
  @@index([email])
  @@index([createdAt])
}

model TicketMessage {
  id             String           @id @default(cuid())
  ticketId       String
  ticket         Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorType     TicketAuthorType
  /// Staff author (null for customer messages)
  userId         String?
  user           User?            @relation("TicketMessageAuthor", fields: [userId], references: [id])
  body           String
  /// Resend email_id of the inbound mail that created this message (dedupe on webhook retries)
  inboundEmailId String?          @unique
  createdAt      DateTime         @default(now())

  @@index([ticketId, createdAt])
}

/// Single-row-per-year counter for sequential ticket numbers (locked via transaction)
model TicketCounter {
  year         Int @id
  lastSequence Int @default(0)
}

// ---------- Logging ----------

model EmailLog {
  id        String      @id @default(cuid())
  to        String
  template  String
  subject   String
  status    EmailStatus
  payload   Json?
  error     String?
  createdAt DateTime    @default(now())
}

model ConsentLog {
  id          String   @id @default(cuid())
  /// Anonymous client id (random, stored alongside consent in the browser)
  anonymousId String?
  necessary   Boolean  @default(true)
  statistics  Boolean
  marketing   Boolean
  version     String
  locale      Locale?
  userAgent   String?
  createdAt   DateTime @default(now())
}

// ---------- Shop settings ----------

/// Singleton row (id = "singleton"). Tracking IDs are public in page source by
/// nature, but only loaded client-side after the matching consent category.
model ShopSettings {
  id               String   @id @default("singleton")
  metaPixelId      String?
  ga4MeasurementId String?
  gtmContainerId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------- Social media planner ----------

/// Ein Post pro Plattform-Ziel: "beide Plattformen" erzeugt zwei Zeilen.
/// Idempotenz beim Publishing: Status-CAS (updateMany auf status=scheduled),
/// lockUntil gegen parallele Worker, publishRequestId pro Versuch.
model SocialMediaPost {
  id        String           @id @default(cuid())
  platform  SocialPlatform
  status    SocialPostStatus @default(draft)
  caption   String
  /// Bild-URLs (Produkt-Assets oder hochgeladene Medien), app-relativ oder absolut
  mediaUrls String[]

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  /// Veröffentlichungszeit in UTC (Eingabe in Admin-Zeitzone, Umrechnung im Editor)
  scheduledAt DateTime?
  publishedAt DateTime?

  errorMessage     String?
  /// ID des Posts auf der Zielplattform (Graph API)
  externalPostId   String?
  /// Publisher, der den Post veröffentlicht (mock | meta)
  provider         String    @default("mock")
  attempts         Int       @default(0)
  lastAttemptAt    DateTime?
  /// Worker-Lock: solange in der Zukunft, darf kein anderer Worker den Post anfassen
  lockUntil        DateTime?
  /// Eindeutige ID des laufenden Publish-Versuchs (Idempotenz-Nachweis)
  publishRequestId String?   @unique
  metadata         Json?

  createdById String?
  createdBy   User?    @relation("SocialPostAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([platform, status])
  @@index([productId])
  @@index([createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation("AuditActor", fields: [userId], references: [id])
  action     String
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------- Reklamationen ----------

model Complaint {
  id              String          @id @default(cuid())
  /// z. B. REK-2026-00001 (ComplaintCounter, jahresweise)
  complaintNumber String          @unique
  /// Kundenzugriff auf die Reklamation (analog Ticket.accessToken)
  accessToken     String          @unique
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id])
  status          ComplaintStatus @default(submitted)
  reason          ComplaintReason
  description     String
  /// Staff-only — niemals in Public-Responses
  internalNote    String?
  ticketId        String?         @unique
  ticket          Ticket?         @relation(fields: [ticketId], references: [id])
  closedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items       ComplaintItem[]
  attachments ComplaintAttachment[]
  decisions   ComplaintDecision[]

  @@index([orderId])
  @@index([status])
}

model ComplaintItem {
  id          String    @id @default(cuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  quantity    Int       @default(1)
  note        String?

  @@unique([complaintId, orderItemId])
}

model ComplaintAttachment {
  id           String           @id @default(cuid())
  complaintId  String
  complaint    Complaint        @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  originalName String
  /// Absoluter Pfad im UPLOAD_DIR — niemals in Public-Responses
  storedPath   String
  mimeType     String
  sizeBytes    Int
  uploadedBy   AttachmentAuthor @default(customer)
  createdAt    DateTime         @default(now())
}

/// Entscheidung zu einer Reklamation. Mehrere pro Reklamation möglich
/// (z. B. weitere Prüfung → endgültige Entscheidung).
model ComplaintDecision {
  id                String              @id @default(cuid())
  complaintId       String
  complaint         Complaint           @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  resolution        ComplaintResolution
  note              String?
  refundAmountCents Int?
  voucherCode       String?
  reprintJobId      String?             @unique
  reprintJob        PrinterJob?         @relation(fields: [reprintJobId], references: [id])
  decidedById       String?
  decidedBy         User?               @relation("ComplaintDecider", fields: [decidedById], references: [id])
  decidedAt         DateTime            @default(now())

  @@index([complaintId])
}

model ComplaintCounter {
  year         Int @id
  lastSequence Int @default(0)
}

// ---------- Versand ----------

model Shipment {
  id                  String         @id @default(cuid())
  /// z. B. VER-2026-00001 (ShipmentCounter, jahresweise)
  shipmentNumber      String         @unique
  orderId             String
  order               Order          @relation(fields: [orderId], references: [id])
  status              ShipmentStatus @default(waiting_for_qc)
  carrier             Carrier?
  trackingNumber      String?
  packedAt            DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  weightGrams         Int?
  notes               String?
  packingListPdfPath  String?
  deliveryNotePdfPath String?
  createdById         String?
  createdBy           User?          @relation("ShipmentAuthor", fields: [createdById], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  items        ShipmentItem[]
  statusEvents ShipmentStatusEvent[]
  qcRecords    QcRecord[]

  @@index([orderId])
  @@index([status])
}

model ShipmentItem {
  id          String    @id @default(cuid())
  shipmentId  String
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  quantity    Int       @default(1)

  @@unique([shipmentId, orderItemId])
}

/// Versandhistorie: jeder Statuswechsel wird protokolliert
model ShipmentStatusEvent {
  id         String          @id @default(cuid())
  shipmentId String
  shipment   Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  fromStatus ShipmentStatus?
  toStatus   ShipmentStatus
  byUserId   String?
  byUser     User?           @relation("ShipmentEventActor", fields: [byUserId], references: [id])
  note       String?
  createdAt  DateTime        @default(now())

  @@index([shipmentId])
}

model ShipmentCounter {
  year         Int @id
  lastSequence Int @default(0)
}

// ---------- Kundenbereich (Magic-Link) ----------

/// Magic-Link-Token für den Kundenbereich. Es wird NUR der sha256-Hash
/// gespeichert (analog PasswordResetToken) — nie der Klartext.
model MagicLinkToken {
  id         String    @id @default(cuid())
  /// lowercased — Scope: alle Bestellungen/Angebote dieser E-Mail
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  useCount   Int       @default(0)
  /// gesetzt, wenn durch neuere Links verdrängt (max. 3 aktive pro E-Mail)
  revokedAt  DateTime?
  requestIp  String?
  createdAt  DateTime  @default(now())

  accessLogs PortalAccessLog[]

  @@index([email])
}

model PortalAccessLog {
  id        String         @id @default(cuid())
  tokenId   String
  token     MagicLinkToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  action    String
  entityId  String?
  ip        String?
  createdAt DateTime       @default(now())

  @@index([tokenId, createdAt])
}

// ---------- Konfigurator ----------

/// Geteilte/gespeicherte Farbkombination. Dedupliziert pro Produkt+Kombination
/// (kanonischer Key), damit Share-Links stabil bleiben.
model SavedConfiguration {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Record<ColorZoneSlot, colorId> — gleiche Form wie OrderItem.colorSelection
  selectedColors Json
  previewImage   String?
  shareToken     String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
}

// ---------- Bewertungen ----------

model Review {
  id            String       @id @default(cuid())
  /// genau eine Bewertung pro Bestellposition
  orderItemId   String       @unique
  orderItem     OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// 1–5 (Zod-validiert)
  rating        Int
  title         String?
  body          String
  /// Absoluter Pfad im UPLOAD_DIR — öffentlich nur bei status=approved
  photoPath     String?
  /// Einziges öffentlich sichtbares Kunden-Feld
  displayName   String
  locale        Locale       @default(de)
  status        ReviewStatus @default(pending)
  /// Staff-only
  internalNote  String?
  flaggedAbuse  Boolean      @default(false)
  moderatedById String?
  moderatedBy   User?        @relation("ReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  moderatedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([productId, status])
  @@index([status])
}
