{
  "name": "3d-print-shop",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=!@print-shop/e2e",
    "e2e": "pnpm --filter @print-shop/e2e test",
    "storybook": "pnpm --filter @print-shop/ui storybook",
    "storybook:build": "pnpm --filter @print-shop/ui storybook:build",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @print-shop/api prisma:migrate",
    "db:seed": "pnpm --filter @print-shop/api prisma:seed",
    "prisma:validate": "pnpm --filter @print-shop/api prisma:validate",
    "format": "prettier --write \"**/*.{ts,vue,json,md,yaml,yml,css}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
